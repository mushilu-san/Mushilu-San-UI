{
  "name": "mushilu-san-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build ui",
    "build:watch": "ng build ui --watch --configuration development",
    "test": "ng test ui",
    "test:ci": "ng test ui --no-watch",
    "storybook": "ng run ui:storybook",
    "storybook:build": "ng run ui:build-storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "lint": "ng lint ui",
    "format": "prettier --write \"projects/**/*.{ts,html,css,mjs,json}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,css,mjs,json}\"",
    "size": "size-limit",
    "build-storybook": "ng run ui:build-storybook"
  },
  "private": true,
  "workspaces": [
    "projects/ui"
  ],
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@changesets/cli": "^2.31.0",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-onboarding": "^10.4.2",
    "@storybook/angular": "^10.4.2",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "21.4.0",
    "eslint": "^10.5.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  },
  "size-limit": [
    {
      "name": "primitives",
      "path": "dist/ui/fesm2022/mushilu-san-ui-primitives.mjs",
      "limit": "8 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "forms",
      "path": "dist/ui/fesm2022/mushilu-san-ui-forms.mjs",
      "limit": "12 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "layout",
      "path": "dist/ui/fesm2022/mushilu-san-ui-layout.mjs",
      "limit": "7 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "navigation",
      "path": "dist/ui/fesm2022/mushilu-san-ui-navigation.mjs",
      "limit": "8 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "feedback",
      "path": "dist/ui/fesm2022/mushilu-san-ui-feedback.mjs",
      "limit": "9 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "data-display",
      "path": "dist/ui/fesm2022/mushilu-san-ui-data-display.mjs",
      "limit": "10 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "mobile",
      "path": "dist/ui/fesm2022/mushilu-san-ui-mobile.mjs",
      "limit": "8 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    },
    {
      "name": "overlays",
      "path": "dist/ui/fesm2022/mushilu-san-ui-overlays.mjs",
      "limit": "10 KB",
      "ignore": ["@angular/common", "@angular/compiler", "@angular/core", "@angular/forms", "@angular/platform-browser", "@angular/router", "chart.js", "rxjs", "tslib"]
    }
  ],
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  }
}
