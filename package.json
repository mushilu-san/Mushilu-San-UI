{
  "name": "mushilu-san-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "nx build ui",
    "build:watch": "nx build ui --watch --configuration development",
    "test": "nx test ui",
    "test:ci": "nx test ui --no-watch",
    "test:affected": "node scripts/affected-run.mjs unit",
    "storybook": "nx run ui:storybook",
    "storybook:build": "nx run ui:build-storybook",
    "changeset": "changeset",
    "lint": "nx lint ui",
    "format": "prettier --write \"projects/**/*.{ts,html,css,mjs,json}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,css,mjs,json}\"",
    "size": "size-limit",
    "build-storybook": "nx run ui:build-storybook",
    "e2e": "playwright test",
    "e2e:affected": "node scripts/affected-run.mjs e2e",
    "e2e:report": "playwright show-report",
    "test:scripts": "vitest run --config vitest.scripts.config.mjs"
  },
  "private": true,
  "workspaces": [
    "projects/ui"
  ],
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "chart.js": "^4.5.1"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2200.6",
    "@angular-devkit/build-angular": "^22.0.6",
    "@angular-devkit/core": "^22.0.6",
    "@angular-devkit/schematics": "^22.0.6",
    "@angular/build": "^22.0.1",
    "@angular/cdk": "^22.0.4",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@ngx-playwright/harness": "^0.12.1",
    "@ngx-playwright/test": "^0.6.1",
    "@nx/angular": "23.1.0",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "^22.0.4",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "22.0.0",
    "chart.js": "^4.5.1",
    "eslint": "^10.6.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.1",
    "nx": "23.0.1",
    "prettier": "^3.9.4",
    "serve": "^14.2.6",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.6",
    "typescript": "~6.0.0",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.9"
