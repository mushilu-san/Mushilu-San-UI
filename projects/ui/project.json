{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ui",
  "projectType": "library",
  "sourceRoot": "projects/ui/src",
  "prefix": "mui",
  "targets": {
    "build": {
      "executor": "@angular/build:ng-packagr",
      "configurations": {
        "production": {
          "tsConfig": "projects/ui/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "projects/ui/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "tsConfig": "projects/ui/tsconfig.spec.json",
        "setupFiles": ["projects/ui/src/test-setup.ts"],
        "include": ["projects/ui/src/**/*.spec.ts"],
        "coverage": true,
        "coverageReporters": ["text", "lcov", "html"],
        "coverageExclude": ["**/testing/**", "**/*.stories.ts"]
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "configDir": "projects/ui/.storybook",
        "browserTarget": "ui:build",
        "compodoc": false,
        "port": 6006,
        "styles": ["projects/ui/src/styles/tokens.css"]
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "options": {
        "configDir": "projects/ui/.storybook",
        "browserTarget": "ui:build",
        "compodoc": false,
        "outputDir": "storybook-static",
        "styles": ["projects/ui/src/styles/tokens.css"]
      }
    },
    "lint": {
      "executor": "@angular-eslint/builder:lint",
      "options": {
        "lintFilePatterns": ["projects/ui/**/*.ts", "projects/ui/**/*.html"],
        "eslintConfig": "projects/ui/eslint.config.js"
      },
      "outputs": ["{options.outputFile}"]
    }
  }
}
